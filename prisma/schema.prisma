generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SVIP
  SSVIP
  Administer
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ContentVisibility {
  PUBLIC
  LOGIN_REQUIRED
  SVIP_ONLY
  SSVIP_ONLY
  Administer_ONLY
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  HIDDEN
  DELETED
}

enum GuestbookStatus {
  PENDING
  APPROVED
  HIDDEN
  DELETED
}

enum VerificationCodeType {
  REGISTER
  LOGIN
  RESET_PASSWORD
  TOTP_DISABLE
}

enum WebAuthnChallengeType {
  REGISTRATION
  AUTHENTICATION
}

enum LoginEventMethod {
  PASSWORD
  EMAIL_CODE
  TOTP
  RECOVERY
  PASSKEY
  SMTP_FAIL_OPEN
}

enum MailTemplateScene {
  MOMENT_COMMENT
  LOGIN_ALERT
  LOGIN_CODE
  TOTP_DISABLE_CODE
  TOTP_RECOVERY_USED
  COMMENT_REPLY
  EMAIL_VERIFY
  PASSWORD_RESET
  CUSTOM_PAGE_COMMENT
  ARTICLE_COMMENT
  GUESTBOOK_REPLY
  REGISTER_CODE
}

enum MailSendStatus {
  SENT
  FAILED
  SKIPPED
}

enum TranslationStatus {
  NOT_TRANSLATED
  TRANSLATING
  TRANSLATED
  FAILED
}

enum ArticleTranslationJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PublicContentTranslationEntity {
  TAG
  MOMENT
  MOMENT_COMMENT
  GUESTBOOK_MESSAGE
  GUESTBOOK_COMMENT
  SETTING
}

enum PublicContentTranslationJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum MediaReferenceSource {
  ARTICLE
  MOMENT
  PAGE
  USER_AVATAR
  SETTING
  MAIL_TEMPLATE
  ARTICLE_VERSION
  COMMENT
}

enum BackupStatus {
  READY
  FAILED
}

enum SitePushProvider {
  BAIDU
  BING
  GOOGLE
}

enum SitePushAction {
  MANUAL
  BATCH
  AUTO
}

enum SitePushStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

enum SettingType {
  TEXT
  TEXTAREA
  BOOLEAN
  NUMBER
  IMAGE
  JSON
  PASSWORD
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  username           String?                 @unique
  passwordHash       String
  nickname           String
  avatar             String?
  role               UserRole                @default(USER)
  identityId         String?
  status             UserStatus              @default(ACTIVE)
  mutedUntil         DateTime?
  emailVerified      Boolean                 @default(false)
  totpSecret         String?                 @db.Text
  totpEnabled        Boolean                 @default(false)
  totpConfirmedAt    DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  lastLoginAt        DateTime?
  articles           Article[]
  articleVersions    ArticleVersion[]
  comments           Comment[]
  moments            Moment[]
  momentLikes        MomentLike[]
  momentComments     MomentComment[]
  guestbookMessages  GuestbookMessage[]
  guestbookComments  GuestbookComment[]
  guestbookLikes     GuestbookLike[]
  passkeys           PasskeyCredential[]
  totpRecovery       TotpRecoveryCode[]
  webauthnChallenges WebAuthnChallenge[]
  sessions           AuthSession[]
  loginEvents        LoginEvent[]
  pendingAuths       PendingAuth[]
  trustedDevices     TrustedDevice[]
  uploadedMedia      MediaAsset[]
  visitLogs          VisitLog[]
  translationJobs    ArticleTranslationJob[]
  identity           Identity?               @relation(fields: [identityId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([identityId])
  @@index([status])
  @@index([username])
}

model Identity {
  id                 String                   @id @default(cuid())
  key                String                   @unique
  name               String
  description        String?                  @db.Text
  permissions        Json
  builtInRole        UserRole?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  users              User[]
  articleAccessRules ArticleAllowedIdentity[]

  @@index([builtInRole])
}

model AuthSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  deviceName String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginEvent {
  id         String           @id @default(cuid())
  userId     String
  method     LoginEventMethod
  deviceName String?
  ipHash     String?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([method, createdAt])
  @@index([createdAt])
}

model PendingAuth {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  deviceName String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VerificationCode {
  id        String               @id @default(cuid())
  email     String
  codeHash  String
  type      VerificationCodeType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([email, type])
  @@index([expiresAt])
}

model PasskeyCredential {
  id                   String    @id @default(cuid())
  userId               String
  credentialId         String    @unique
  publicKey            String    @db.Text
  counter              Int       @default(0)
  deviceName           String?
  transports           String?   @db.Text
  credentialDeviceType String?
  backedUp             Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lastUsedAt           DateTime?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TotpRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model WebAuthnChallenge {
  id        String                @id @default(cuid())
  userId    String?
  challenge String                @unique
  type      WebAuthnChallengeType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())
  user      User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@index([usedAt])
}

model Article {
  id                String                   @id @default(cuid())
  title             String
  slug              String                   @unique
  summary           String?                  @db.Text
  cover             String?
  contentJson       Json
  contentHtml       String                   @db.LongText
  status            ArticleStatus            @default(DRAFT)
  visibility        ContentVisibility        @default(PUBLIC)
  allowComments     Boolean                  @default(true)
  pinned            Boolean                  @default(false)
  featured          Boolean                  @default(false)
  viewCount         Int                      @default(0)
  seoTitle          String?
  seoDescription    String?                  @db.Text
  authorId          String
  publishedAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  rawImportMeta     Json?
  author            User                     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  tags              ArticleTag[]
  allowedIdentities ArticleAllowedIdentity[]
  versions          ArticleVersion[]
  translations      ArticleTranslation[]
  translationJobs   ArticleTranslationJob[]
  comments          Comment[]
  visitLogs         VisitLog[]

  @@index([status, visibility])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([authorId])
}

model ArticleTranslation {
  id              String            @id @default(cuid())
  articleId       String
  locale          String
  title           String
  summary         String?           @db.Text
  seoTitle        String?
  seoDescription  String?           @db.Text
  contentHtml     String            @db.LongText
  contentJson     Json?
  status          TranslationStatus @default(NOT_TRANSLATED)
  progress        Int               @default(0)
  completedUnits  Int               @default(0)
  totalUnits      Int               @default(0)
  progressMessage String?           @db.Text
  error           String?           @db.Text
  contentHash     String?           @db.VarChar(64)
  sourceUpdatedAt DateTime?
  translatedAt    DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  article         Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale, status])
  @@index([contentHash])
}

model ArticleTranslationJob {
  id              String                      @id @default(cuid())
  articleId       String
  locale          String
  status          ArticleTranslationJobStatus @default(QUEUED)
  progress        Int                         @default(0)
  completedUnits  Int                         @default(0)
  totalUnits      Int                         @default(0)
  progressMessage String?                     @db.Text
  error           String?                     @db.Text
  createdById     String
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  article         Article                     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdBy       User                        @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([articleId, locale, createdAt])
  @@index([status, createdAt])
  @@index([createdById])
}

model PublicContentTranslation {
  id              String                         @id @default(cuid())
  entity          PublicContentTranslationEntity
  entityId        String
  locale          String
  fields          Json
  status          TranslationStatus              @default(NOT_TRANSLATED)
  progress        Int                            @default(0)
  error           String?                        @db.Text
  sourceHash      String?                        @db.VarChar(64)
  sourceUpdatedAt DateTime?
  translatedAt    DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@unique([entity, entityId, locale])
  @@index([entity, locale, status])
  @@index([sourceHash])
}

model PublicContentTranslationJob {
  id          String                            @id @default(cuid())
  entity      PublicContentTranslationEntity
  entityId    String
  locale      String
  fields      Json
  sourceHash  String?                           @db.VarChar(64)
  status      PublicContentTranslationJobStatus @default(QUEUED)
  progress    Int                               @default(0)
  error       String?                           @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime                          @default(now())
  updatedAt   DateTime                          @updatedAt

  @@index([entity, entityId, locale, createdAt])
  @@index([status, createdAt])
  @@index([sourceHash])
}

model Tag {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  color         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  rawImportMeta Json?
  articles      ArticleTag[]

  @@index([name])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

model ArticleVersion {
  id                 String            @id @default(cuid())
  articleId          String
  version            Int
  title              String
  slug               String
  summary            String?           @db.Text
  cover              String?
  contentJson        Json
  contentHtml        String            @db.LongText
  status             ArticleStatus
  visibility         ContentVisibility
  allowComments      Boolean
  pinned             Boolean
  featured           Boolean
  seoTitle           String?
  seoDescription     String?           @db.Text
  tagNames           Json
  allowedIdentityIds Json?
  createdById        String
  createdAt          DateTime          @default(now())
  article            Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdBy          User              @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([articleId, version])
  @@index([articleId, createdAt])
  @@index([createdById])
}

model ArticleAllowedIdentity {
  articleId  String
  identityId String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@id([articleId, identityId])
  @@index([identityId])
}

model Comment {
  id            String        @id @default(cuid())
  articleId     String
  userId        String
  parentId      String?
  content       String        @db.Text
  deviceName    String?
  status        CommentStatus @default(PENDING)
  pinned        Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  rawImportMeta Json?
  article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies       Comment[]     @relation("CommentReplies")

  @@index([articleId, status, pinned])
  @@index([userId])
  @@index([parentId])
}

model Moment {
  id            String            @id @default(cuid())
  content       String            @db.Text
  images        Json
  visibility    ContentVisibility @default(PUBLIC)
  pinned        Boolean           @default(false)
  likeCount     Int               @default(0)
  authorId      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  rawImportMeta Json?
  author        User              @relation(fields: [authorId], references: [id], onDelete: Restrict)
  likes         MomentLike[]
  comments      MomentComment[]

  @@index([visibility, pinned])
  @@index([deletedAt])
}

model MomentLike {
  momentId  String
  userId    String
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([momentId, userId])
  @@index([userId])
}

model MomentComment {
  id         String    @id @default(cuid())
  momentId   String
  userId     String
  content    String    @db.Text
  deviceName String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  moment     Moment    @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([momentId, createdAt])
  @@index([userId])
  @@index([deletedAt])
}

model GuestbookMessage {
  id         String             @id @default(cuid())
  userId     String?
  nickname   String
  email      String
  content    String             @db.Text
  reply      String?            @db.Text
  notifyOnly Boolean            @default(false)
  status     GuestbookStatus    @default(PENDING)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  deletedAt  DateTime?
  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  comments   GuestbookComment[]
  likes      GuestbookLike[]

  @@index([status])
  @@index([deletedAt])
  @@index([userId])
  @@index([notifyOnly, status])
}

model GuestbookComment {
  id        String           @id @default(cuid())
  messageId String
  userId    String?
  nickname  String
  email     String
  content   String           @db.Text
  createdAt DateTime         @default(now())
  deletedAt DateTime?
  message   GuestbookMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@index([userId])
  @@index([deletedAt])
}

model GuestbookLike {
  messageId String
  userId    String
  createdAt DateTime         @default(now())
  message   GuestbookMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId])
}

model Setting {
  id        String      @id @default(cuid())
  key       String      @unique
  value     String      @db.LongText
  group     String
  type      SettingType @default(TEXT)
  updatedAt DateTime    @updatedAt

  @@index([group])
}

model MailTemplate {
  id        String            @id @default(cuid())
  scene     MailTemplateScene @unique
  subject   String
  bodyHtml  String            @db.LongText
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([updatedAt])
}

model MailSendLog {
  id        String            @id @default(cuid())
  scene     MailTemplateScene
  to        String
  subject   String?
  status    MailSendStatus
  error     String?           @db.Text
  createdAt DateTime          @default(now())

  @@index([scene])
  @@index([status])
  @@index([createdAt])
}

model VisitLog {
  id           String   @id @default(cuid())
  path         String
  articleId    String?
  userId       String?
  ipHash       String
  userAgent    String?  @db.Text
  referrer     String?  @db.Text
  referrerHost String?
  searchEngine String?
  countryCode  String?  @db.VarChar(16)
  createdAt    DateTime @default(now())
  article      Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([path])
  @@index([articleId])
  @@index([userId])
  @@index([countryCode])
  @@index([searchEngine])
  @@index([createdAt])
}

model MediaAsset {
  id            String           @id @default(cuid())
  url           String
  filename      String
  mimeType      String
  size          Int
  uploaderId    String?
  createdAt     DateTime         @default(now())
  isUnused      Boolean          @default(false)
  unusedSince   DateTime?
  lastScannedAt DateTime?
  rawImportMeta Json?
  uploader      User?            @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  references    MediaReference[]

  @@index([uploaderId])
  @@index([createdAt])
  @@index([isUnused, unusedSince])
}

model MediaReference {
  id        String               @id @default(cuid())
  assetId   String
  source    MediaReferenceSource
  sourceId  String
  createdAt DateTime             @default(now())
  asset     MediaAsset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, source, sourceId])
  @@index([source, sourceId])
}

model BackupRecord {
  id          String       @id @default(cuid())
  filename    String
  filePath    String       @db.Text
  sizeBytes   Int
  status      BackupStatus @default(READY)
  reason      String?
  error       String?      @db.Text
  createdById String?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
}

model SitePushRecord {
  id           String           @id @default(cuid())
  provider     SitePushProvider
  url          String           @db.Text
  action       SitePushAction
  status       SitePushStatus   @default(PENDING)
  httpStatus   Int?
  responseBody String?          @db.Text
  error        String?          @db.Text
  createdAt    DateTime         @default(now())
  submittedAt  DateTime?

  @@index([provider])
  @@index([status])
  @@index([createdAt])
  @@index([submittedAt])
}

model SystemInstallation {
  id                String    @id @default("main")
  installed         Boolean   @default(false)
  installedAt       DateTime?
  setupTokenDeleted Boolean   @default(false)
}
