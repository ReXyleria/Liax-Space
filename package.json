{
  "name": "liax-space",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm ci --prefix apps/server && npm ci --prefix apps/admin",
    "build": "npm run build --prefix apps/server && npm run build --prefix apps/admin",
    "typecheck": "npm run typecheck --prefix apps/server && npm run typecheck --prefix apps/admin",
    "test": "npm run test --prefix apps/server && npm run test --prefix apps/admin",
    "test:unit": "npm run test:unit --prefix apps/server && npm run test:unit --prefix apps/admin",
    "test:integration": "npm run test:integration --prefix apps/server && npm run test:integration --prefix apps/admin",
    "test:visual": "npm run test:visual --prefix apps/admin",
    "check:design": "node scripts/check-design-tokens.ts",
    "check:env": "node scripts/check-env.ts",
    "check:consistency": "node scripts/check-consistency.ts",
    "check:acceptance": "node scripts/check-acceptance.ts",
    "check:docker-context": "node scripts/check-docker-context.ts",
    "check:install": "node scripts/check-install-chain.ts",
    "create-setup-token": "node scripts/create-setup-token.ts",
    "rebuild-html": "node scripts/rebuild-html.ts",
    "backup": "node scripts/backup.ts",
    "restore": "node scripts/restore.ts",
    "cleanup:rendered": "node scripts/cleanup-rendered-html.ts",
    "cleanup:attachments": "node scripts/cleanup-unused-attachments.ts",
    "migrate:latest": "npm run migrate:latest --prefix apps/server",
    "migrate:rollback": "npm run migrate:rollback --prefix apps/server",
    "seed": "npm run seed --prefix apps/server",
    "dev:server": "npm run dev --prefix apps/server",
    "dev:admin": "npm run dev --prefix apps/admin",
    "start": "npm run start --prefix apps/server",
    "docker:compose:config": "docker compose config",
    "docker:build": "docker build -t liax-space:local ."
  }
}
